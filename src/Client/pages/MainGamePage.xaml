<Page
    x:Class="MuddyClient.Pages.MainGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#1A1A1A">

    <Page.Resources>
        <Style x:Key="PanelHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#7B3A10"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CornerRadius" Value="3,3,0,0"/>
        </Style>
        <Style x:Key="GreenHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#2E5C2E"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CornerRadius" Value="3,3,0,0"/>
        </Style>
        <Style x:Key="BlueHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#1E3A5F"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CornerRadius" Value="3,3,0,0"/>
        </Style>
        <Style x:Key="PanelBodyStyle" TargetType="Border">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0,0,3,3"/>
        </Style>
        <Style x:Key="SpellButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4,6"/>
        </Style>
        <Style x:Key="SysButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4,8"/>
        </Style>
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E3A5F"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2E5A8F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>
    </Page.Resources>

    <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="2" Margin="6" CornerRadius="4">
        <Grid Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <StackPanel Grid.Column="0" Margin="0,0,6,0" Spacing="6">

                <!-- Quick Cast Spells -->
                <StackPanel>
                    <Border Style="{StaticResource PanelHeaderStyle}">
                        <TextBlock Text="Quick Cast Spells" Foreground="White" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <Border Style="{StaticResource PanelBodyStyle}" Padding="6">
                        <StackPanel>
                            <Button Content="Fireball"      Style="{StaticResource SpellButtonStyle}" Click="SpellButton_Click"/>
                            <Button Content="Heal"          Style="{StaticResource SpellButtonStyle}" Click="SpellButton_Click"/>
                            <Button Content="Lightning Bolt" Style="{StaticResource SpellButtonStyle}" Click="SpellButton_Click"/>
                            <Button Content="Shield"        Style="{StaticResource SpellButtonStyle}" Click="SpellButton_Click"/>
                            <Button Content="Empty"         Style="{StaticResource SpellButtonStyle}" IsEnabled="False" Foreground="#666666"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Player Stats -->
                <StackPanel>
                    <Border Style="{StaticResource GreenHeaderStyle}">
                        <TextBlock Text="Player Stats" Foreground="White" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <Border Style="{StaticResource PanelBodyStyle}" Padding="10,8">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="txtHP"   Foreground="#DDDDDD" FontSize="13" FontFamily="Consolas"/>
                            <Border BorderBrush="#444" BorderThickness="0,0,0,1"/>
                            <TextBlock x:Name="txtMana" Foreground="#DDDDDD" FontSize="13" FontFamily="Consolas"/>
                            <Border BorderBrush="#444" BorderThickness="0,0,0,1"/>
                            <TextBlock x:Name="txtXP"   Foreground="#DDDDDD" FontSize="13" FontFamily="Consolas"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Inventory -->
                <StackPanel>
                    <Border Style="{StaticResource GreenHeaderStyle}">
                        <TextBlock Text="Inventory" Foreground="White" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <Border Style="{StaticResource PanelBodyStyle}" Padding="6">
                        <StackPanel x:Name="InventoryList" Spacing="0"/>
                    </Border>
                </StackPanel>

            </StackPanel>

            <!-- CENTER PANEL -->
            <Grid Grid.Column="1" Margin="0,0,6,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#444444" BorderThickness="1" CornerRadius="3">
                    <Grid>
                        <Rectangle Fill="#1C1612"/>
                        <Rectangle Opacity="0.15">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3D2B1A" Offset="0"/>
                                    <GradientStop Color="#1A1208" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <ScrollViewer x:Name="GameScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="12">
                            <RichTextBlock x:Name="GameTextBox"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True"
                                           LineHeight="22"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CommandInput"
                             Grid.Column="0"
                             PlaceholderText="Type your command here..."
                             Background="#2A2A2A"
                             Foreground="#DDDDDD"
                             BorderBrush="#555555"
                             FontFamily="Consolas"
                             FontSize="14"
                             Padding="10,8"
                             KeyDown="CommandInput_KeyDown"/>
                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Content="Send"
                            Style="{StaticResource SendButtonStyle}"
                            Margin="6,0,0,0"
                            Click="SendButton_Click"/>
                </Grid>
            </Grid>

            <!-- RIGHT PANEL -->
            <StackPanel Grid.Column="2" Spacing="6">

                <!-- Map -->
                <StackPanel>
                    <Border Style="{StaticResource BlueHeaderStyle}">
                        <TextBlock Text="Map" Foreground="White" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <Border Style="{StaticResource PanelBodyStyle}" Height="180" Padding="6">
                        <Canvas x:Name="MinimapCanvas" Background="#111111">
                            <Rectangle Canvas.Left="70" Canvas.Top="70" Width="20" Height="20" Fill="#2E6FBF" Stroke="#5599DD" StrokeThickness="1"/>
                            <Rectangle Canvas.Left="100" Canvas.Top="70" Width="20" Height="20" Fill="#555555" Stroke="#888888" StrokeThickness="1"/>
                            <Rectangle Canvas.Left="40"  Canvas.Top="70" Width="20" Height="20" Fill="#555555" Stroke="#888888" StrokeThickness="1"/>
                            <Rectangle Canvas.Left="70"  Canvas.Top="100" Width="20" Height="20" Fill="#555555" Stroke="#888888" StrokeThickness="1"/>
                            <Rectangle Canvas.Left="100" Canvas.Top="100" Width="20" Height="20" Fill="#555555" Stroke="#888888" StrokeThickness="1"/>
                            <Line X1="90"  Y1="80" X2="100" Y2="80" Stroke="#888888" StrokeThickness="1"/>
                            <Line X1="60"  Y1="80" X2="70"  Y2="80" Stroke="#888888" StrokeThickness="1"/>
                            <Line X1="80"  Y1="90" X2="80"  Y2="100" Stroke="#888888" StrokeThickness="1"/>
                            <Line X1="110" Y1="90" X2="110" Y2="100" Stroke="#888888" StrokeThickness="1"/>
                        </Canvas>
                    </Border>
                </StackPanel>

                <!-- System Options -->
                <StackPanel>
                    <Border Style="{StaticResource PanelHeaderStyle}">
                        <TextBlock Text="System Options" Foreground="White" FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <Border Style="{StaticResource PanelBodyStyle}" Padding="8">
                        <StackPanel>
                            <Button Content="Settings" Style="{StaticResource SysButtonStyle}" Click="Settings_Click"/>
                            <Button Content="Logs"     Style="{StaticResource SysButtonStyle}" Click="Logs_Click"/>
                            <Button Content="Help"     Style="{StaticResource SysButtonStyle}" Click="Help_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</Page>
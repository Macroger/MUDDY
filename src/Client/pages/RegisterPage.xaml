<Page
    x:Class="MuddyClient.Pages.RegisterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="10" Padding="30">

        <TextBlock Text="Create Account" FontSize="24"/>

        <TextBox x:Name="txtUsername" Header="Username"/>
        <PasswordBox x:Name="txtPassword" Header="Password"/>
        <PasswordBox x:Name="txtConfirm" Header="Confirm Password"/>

        <Button Content="Register" Click="Register_Click"/>
        <Button Content="Back" Click="Back_Click"/>

        <TextBlock x:Name="lblStatus"/>

    </StackPanel>
</Page>
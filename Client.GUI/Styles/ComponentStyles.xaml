<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="PanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>


    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0.5" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style x:Key="HighlightPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource HighlightBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AccentPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>


    <Style x:Key="HeroPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AccentPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>


    <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{ThemeResource AccentPrimaryBrush}" />
    </Style>


    <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>


    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource ButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource ButtonForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
    </Style>


    <Style x:Key="GlowBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{ThemeResource HighlightBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>


    <Style x:Key="CommandTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{ThemeResource PanelBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>


    <Style x:Key="FilterPillStyle" TargetType="ToggleButton">

        <!-- Core appearance (contract-driven) -->
        <Setter Property="Background" Value="{ThemeResource CardBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1"/>

        <!-- Shape + layout -->
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="MinHeight" Value="28"/>

    </Style>










</ResourceDictionary>

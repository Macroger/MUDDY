<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Client.GUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client.GUI">
    <Application.Resources>
        <ResourceDictionary>            
            <ResourceDictionary.MergedDictionaries>

                <!-- MUST BE FIRST -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />

                <!-- CONTRACT -->
                <ResourceDictionary Source="ms-appx:///Themes/ThemeContract.xaml"/>

                <!-- ACTIVE THEME (REPLACED AT RUNTIME) -->
                <ResourceDictionary Source="ms-appx:///Themes/DefaultTheme.xaml"/>

                <!-- COMPONENT STYLES -->
                <ResourceDictionary Source="ms-appx:///Styles/ComponentStyles.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- Global Font -->
            <FontFamily x:Key="ContentControlThemeFontFamily">Arial</FontFamily>
            <FontFamily x:Key="TextControlThemeFontFamily">Arial</FontFamily>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>

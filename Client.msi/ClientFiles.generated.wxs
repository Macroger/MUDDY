      <Component Id="cmp_ClientFiles_StartMenuShortcut" Guid="9a5763af-ea5e-4cc9-a519-b1baa9ff0cfe">
        <RegistryValue
          Root="HKCU"
          Key="Software\MUDDY\ClientFiles"
          Name="Installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
        <Shortcut
          Id="ClientFilesStartMenuShortcut"
          Directory="ProgramMenuFolder"
          Name="MUDDY Client"
          Target="[ClientFolder]Client.GUI.exe"
          WorkingDirectory="ClientFolder"
          Icon="ClientIcon" />
        <RemoveFolder
          Id="RemoveMUDDYProgramMenuFolder_ClientFiles"
          Directory="ProgramMenuFolder"
          On="uninstall" />

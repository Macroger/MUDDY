# Doxyfile for Project IV - MUDDY MUD Server & Client
# Enhanced configuration combining C# best practices with comprehensive documentation

#---------------------------------------------------------------------------
# Project Information
#---------------------------------------------------------------------------

PROJECT_NAME           = "MUDDY - Multi-User Dungeon (for) Dynamic Learning - Server & Client Applications"
PROJECT_BRIEF          = "A networked MUD game server and client with custom network packet, command pipeline architecture, and OOP design philosophy."
PROJECT_NUMBER         = "1.0"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO

#---------------------------------------------------------------------------
# Input Configuration
#---------------------------------------------------------------------------

INPUT                  = Server.Core \
                         Server.GUI \
                         Client.Core \
                         Client.GUI \
                         Shared
RECURSIVE              = YES
FILE_PATTERNS          = *.cs
EXTENSION_MAPPING      = cs=C#
EXCLUDE_PATTERNS       = */bin/* \
                         */obj/* \
                         */packages/* \
                         */.vs/* \
                         */Debug/* \
                         */Release/*

#---------------------------------------------------------------------------
# C# Specific Settings
#---------------------------------------------------------------------------

OPTIMIZE_OUTPUT_FOR_CSHARP = YES
MARKDOWN_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = NO
TYPEDEF_HIDES_STRUCT   = YES

#---------------------------------------------------------------------------
# Extraction Settings
#---------------------------------------------------------------------------

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_PACKAGE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_METHODS  = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
INTERNAL_DOCS          = YES

#---------------------------------------------------------------------------
# Build Output Settings
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = AUTO_LIGHT
HTML_TIMESTAMP         = YES
HTML_DYNAMIC_MENUS     = YES
HTML_DYNAMIC_SECTIONS  = YES

GENERATE_XML           = YES
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = YES

GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Search & Navigation
#---------------------------------------------------------------------------

SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO

#---------------------------------------------------------------------------
# Preprocessing
#---------------------------------------------------------------------------

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
SKIP_FUNCTION_MACROS   = YES

#---------------------------------------------------------------------------
# Diagrams & Graphs (requires Graphviz)
#---------------------------------------------------------------------------

HAVE_DOT               = YES
DOT_PATH               = "C:/Program Files/Graphviz/bin"
DOT_NUM_THREADS        = 0
DOT_IMAGE_FORMAT       = svg
DOT_TRANSPARENT        = YES
DOT_MULTI_TARGETS      = YES

CLASS_DIAGRAMS         = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
UML_LOOK               = YES
UML_LIMIT_NUM_FIELDS   = 10
DOT_UML_DETAILS        = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES

#---------------------------------------------------------------------------
# Warning & Error Settings
#---------------------------------------------------------------------------

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO
WARN_FORMAT            = "$file:$line: $text"

#---------------------------------------------------------------------------
# Miscellaneous Settings
#---------------------------------------------------------------------------

QUIET                  = NO
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES
ALPHABETICAL_INDEX     = YES
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES

#---------------------------------------------------------------------------
# Main Page Configuration
#---------------------------------------------------------------------------

# Use README.md at repo root as main page if present
USE_MDFILE_AS_MAINPAGE = README.md

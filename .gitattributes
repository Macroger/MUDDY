# Default: normalize to LF in the repo, CRLF on Windows checkout
* text=auto eol=crlf

# WiX source files
*.wxs text eol=crlf
*.wxl text eol=crlf
*.wixproj text eol=crlf

# PowerShell scripts
*.ps1 text eol=crlf

# C# / project files
*.cs text eol=crlf
*.csproj text eol=crlf
*.slnx text eol=crlf
*.sln text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf

# XML / config
*.xml text eol=crlf
*.json text eol=crlf
*.config text eol=crlf

# RTF (installer license)
*.rtf text eol=crlf

# Binary files — never touch line endings
*.ico binary
*.exe binary
*.dll binary
*.msi binary
*.cab binary
*.png binary
*.jpg binary
*.jpeg binary

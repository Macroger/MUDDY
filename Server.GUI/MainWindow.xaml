<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Server.GUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Server.GUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MUDDY Server Dashboard">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#141414">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="230"/>
        </Grid.RowDefinitions>

        <!-- ===== ROW 0: TOP STATUS BAR ===== -->
        <Border Grid.Row="0" Background="#1A1A1A"
                BorderBrush="#B8610A" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,0,0" Spacing="8">
                    <Border Width="3" Height="20" Background="#B8610A"/>
                    <TextBlock x:Name="ServerTimeText"
                               Text="SERVER TIME: 00:00:00"
                               Foreground="#E8A040" FontWeight="Bold" FontSize="13"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#1E3A1E"
                        BorderBrush="#4CAF50" BorderThickness="1"
                        Padding="24,6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center"/>
                        <TextBlock Text="STATUS: ONLINE"
                                   Foreground="#4CAF50" FontWeight="Bold" FontSize="13"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right"
                            Margin="0,0,16,0" Spacing="8">
                    <TextBlock x:Name="PlayerCountText"
                               Text="PLAYERS: 0"
                               Foreground="#E8A040" FontWeight="Bold" FontSize="13"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                    <Border Width="3" Height="20" Background="#B8610A"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== ROW 1: TABS ===== -->
        <Border Grid.Row="1" Background="#1A1A1A"
                BorderBrush="#333" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="2" Padding="12,6">
                <Border Background="#B8610A" Padding="16,6">
                    <TextBlock Text="DASHBOARD" Foreground="White"
                               FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                </Border>
                <Border Background="Transparent" Padding="16,6"
                        BorderBrush="#333" BorderThickness="1">
                    <TextBlock Text="LOGS" Foreground="#666"
                               FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== ROW 2: MAIN CONTENT ===== -->
        <Grid Grid.Row="2" Margin="12,12,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Server Status Panel -->
            <Border Grid.Column="0" Background="#1A1A1A"
                    BorderBrush="#B8610A" BorderThickness="1"
                    Margin="0,0,8,0">
                <StackPanel>
                    <Border Background="#B8610A" Padding="10,7">
                        <TextBlock Text="SERVER STATUS" Foreground="White"
                                   FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                    </Border>
                    <StackPanel Padding="12,12" Spacing="12">
                        <StackPanel Spacing="2">
                            <TextBlock Text="UPTIME" Foreground="#666"
                                       FontSize="10" FontFamily="Consolas"/>
                            <TextBlock x:Name="UptimeText" Text="00:00:00"
                                       Foreground="#E8A040" FontWeight="Bold"
                                       FontSize="16" FontFamily="Consolas"/>
                        </StackPanel>
                        <Border Height="1" Background="#2A2A2A"/>
                        <StackPanel Spacing="2">
                            <TextBlock Text="STATE" Foreground="#666"
                                       FontSize="10" FontFamily="Consolas"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="7" Height="7" Fill="#4CAF50" VerticalAlignment="Center"/>
                                <TextBlock Text="RUNNING" Foreground="#4CAF50"
                                           FontWeight="Bold" FontSize="13" FontFamily="Consolas"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Active Players Panel -->
            <Border Grid.Column="1" Background="#1A1A1A"
                    BorderBrush="#333" BorderThickness="1">
                <StackPanel>
                    <Border Background="#222" Padding="10,7"
                            BorderBrush="#333" BorderThickness="0,0,0,1">
                        <TextBlock Text="ACTIVE PLAYERS" Foreground="White"
                                   FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                    </Border>

                    <!-- Column Headers -->
                    <Border Background="#1E1E1E" Padding="12,6"
                            BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NAME"
                                       Foreground="#B8610A" FontWeight="Bold"
                                       FontSize="11" FontFamily="Consolas"/>
                            <TextBlock Grid.Column="1" Text="LOCATION"
                                       Foreground="#B8610A" FontWeight="Bold"
                                       FontSize="11" FontFamily="Consolas"/>
                            <TextBlock Grid.Column="2" Text="PING"
                                       Foreground="#B8610A" FontWeight="Bold"
                                       FontSize="11" FontFamily="Consolas"/>
                        </Grid>
                    </Border>

                    <ListView x:Name="PlayersListView" Background="Transparent"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="#2A2A2A"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                               Foreground="#E0E0E0" FontFamily="Consolas"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Location}"
                                               Foreground="#E0E0E0" FontFamily="Consolas"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Ping}"
                                               Foreground="#E8A040" FontFamily="Consolas"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== ROW 3: EVENT LOG ===== -->
        <Border Grid.Row="3" Background="#1A1A1A"
                BorderBrush="#333" BorderThickness="1"
                Margin="12,0,12,12">
            <StackPanel>
                <Border Background="#222" Padding="10,7"
                        BorderBrush="#333" BorderThickness="0,0,0,1">
                    <TextBlock Text="EVENT LOG" Foreground="White"
                               FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                </Border>

                <!-- Log Column Headers -->
                <Border Background="#1E1E1E" Padding="12,5"
                        BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TIME"
                                   Foreground="#B8610A" FontWeight="Bold"
                                   FontSize="11" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="1" Text="SOURCE"
                                   Foreground="#B8610A" FontWeight="Bold"
                                   FontSize="11" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="2" Text="MESSAGE"
                                   Foreground="#B8610A" FontWeight="Bold"
                                   FontSize="11" FontFamily="Consolas"/>
                        <TextBlock Grid.Column="3" Text="SEVERITY"
                                   Foreground="#B8610A" FontWeight="Bold"
                                   FontSize="11" FontFamily="Consolas"/>
                    </Grid>
                </Border>

                <ListView x:Name="EventLogListView" Height="110"
                          Background="Transparent" SelectionMode="None">
                    <ListView.Resources>
                        <local:SeverityColorConverter x:Key="SeverityColorConverter"/>
                    </ListView.Resources>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="#222"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Time}"
                                           Foreground="#666" FontFamily="Consolas" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding Source}"
                                           Foreground="#888" FontFamily="Consolas" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="{Binding Message}"
                                           Foreground="#C0C0C0" FontFamily="Consolas" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3" Text="{Binding Severity}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{Binding Severity, Converter={StaticResource SeverityColorConverter}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="6" Padding="12,6"
                            HorizontalAlignment="Right">
                    <Border Background="#2A2A2A" BorderBrush="#444" BorderThickness="1"
                            Padding="14,5">
                        <TextBlock Text="CLEAR" Foreground="#AAA"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#2A2A2A" BorderBrush="#444" BorderThickness="1"
                            Padding="14,5">
                        <TextBlock Text="PAUSE" Foreground="#AAA"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
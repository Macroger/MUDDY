<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Server.GUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Server.GUI"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:muxc="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d"
    Title="MUDDY Server Dashboard"
    x:Name="MainWindowRoot">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <!-- Value Converters -->
            <local:SeverityColorConverter x:Key="SeverityColorConverter"/>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <!-- Backgrounds -->
            <LinearGradientBrush x:Key="StoneBackground" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4B5566" Offset="0"/>
                <GradientStop Color="#2C3240" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="PanelBackground" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#5A6373" Offset="0"/>
                <GradientStop Color="#3A4251" Offset="1"/>
            </LinearGradientBrush>
            <SolidColorBrush x:Key="PanelBorder" Color="#23262E"/>
            <!-- Orange header solid -->
            <SolidColorBrush x:Key="HeaderOrange" Color="#FF6600"/>
            <!-- Tab styles -->
            <SolidColorBrush x:Key="TabSelected" Color="#FF6600"/>
            <SolidColorBrush x:Key="TabUnselected" Color="#23262E"/>
            <SolidColorBrush x:Key="TabBorder" Color="#23262E"/>
            <!-- Button styles -->
            <LinearGradientBrush x:Key="ButtonBackground" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#6C7686" Offset="0"/>
                <GradientStop Color="#3A4251" Offset="1"/>
            </LinearGradientBrush>
            <SolidColorBrush x:Key="ButtonBorder" Color="#23262E"/>
            <!-- DataGrid styles -->
            <SolidColorBrush x:Key="DataGridHeader" Color="#181A1F"/>
            <SolidColorBrush x:Key="DataGridRow" Color="#23262E"/>
            <SolidColorBrush x:Key="DataGridAltRow" Color="#181A1F"/>
            <!-- Severity colors -->
            <SolidColorBrush x:Key="SeverityInfo" Color="#E8A040"/>
            <SolidColorBrush x:Key="SeverityWarning" Color="#FFD700"/>
            <SolidColorBrush x:Key="SeverityError" Color="#FF4C4C"/>
        </Grid.Resources>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4B5566" Offset="0"/>
                <GradientStop Color="#2C3240" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- The header -->
            <RowDefinition Height="Auto"/>  <!-- The tabbed viewport -->         
            <RowDefinition Height="*"/>     <!-- The footer -->
        </Grid.RowDefinitions>

        <!-- ===== ROW 0: TOP STATUS BAR ===== -->
        <Border Grid.Row="0" Background="{StaticResource HeaderOrange}"
            BorderBrush="#B8610A" BorderThickness="0,0,0,2" CornerRadius="4,4,0,0" Padding="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" x:Name="ServerTimeText" Text="CURRENT TIME: 00:00:00"
                   Foreground="White" FontWeight="Bold" FontSize="14" FontFamily="Consolas"
                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                <Border Grid.Column="1" Background="{StaticResource HeaderOrange}" CornerRadius="3" Padding="8,2"
                            VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="120">
                    <Grid>
                        <TextBlock x:Name="StatusTextBlock" Text="Status: ONLINE"
                           Foreground="Black" FontWeight="Bold" FontSize="16" FontFamily="Consolas"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <TextBlock Grid.Column="2" x:Name="PlayerCountText" Text="Players: 0"
                   Foreground="White" FontWeight="Bold" FontSize="14" FontFamily="Consolas"
                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0"/>
            </Grid>
        </Border>

        <!-- ===== ROW 1: TABS ===== -->
        <TabView Grid.Row="1" Margin="18,18,18,8">
            <TabViewItem Header="Dashboard">
                <!-- Place your current server status, active players, and server metrics grid here -->
                <Grid Margin="18,18,18,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Server Status Panel -->
                    <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="2" CornerRadius="8" Margin="0,0,12,0">
                        <StackPanel>
                            <Border Background="{StaticResource HeaderOrange}" Padding="12,8" CornerRadius="6,6,0,0">
                                <TextBlock Text="Server Status" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14" FontFamily="Consolas"/>
                            </Border>
                            <Grid Padding="16,16,16,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                <!-- Add more RowDefinitions as needed -->
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Server  Uptime -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Server Uptime:" Foreground="#DDD" FontSize="14" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UptimeText" Text="00:00:00" Foreground="#FFB347" FontWeight="Bold" FontSize="16" 
                                           FontFamily="Consolas" VerticalAlignment="Center" Padding="0,4,0,4" HorizontalAlignment="Right" TextAlignment="Right"/>

                                <!-- Server State -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Server State:" Foreground="#DDD" FontSize="14" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <Grid Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding ServerStateBrush, ElementName=MainWindowRoot}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ServerStateText, ElementName=MainWindowRoot}" Foreground="{Binding ServerStateBrush, ElementName=MainWindowRoot}" 
                                               FontWeight="Bold" FontSize="14" FontFamily="Consolas" VerticalAlignment="Center" Padding="0,4,0,4" HorizontalAlignment="Right" TextAlignment="Right"/>
                                </Grid>
                                
                                <!-- Listener State -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Listener:" Foreground="#DDD" FontSize="14" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <Grid Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding ListenerStateBrush, ElementName=MainWindowRoot}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ListenerStateText, ElementName=MainWindowRoot}" Foreground="{Binding ListenerStateBrush, ElementName=MainWindowRoot}" 
                                         FontWeight="Bold" FontSize="14" FontFamily="Consolas" VerticalAlignment="Center" Padding="0,4,0,4" HorizontalAlignment="Right" TextAlignment="Right"/>
                                </Grid>

                                <!-- Toggle Listener Button -->
                                <Grid Grid.Row="3" Grid.ColumnSpan="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button x:Name="ToggleListenerButton" Content="Toggle Listener" Click="ToggleListenerButton_Click" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Add more rows here as needed -->
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Active Players Panel -->
                    <Border Grid.Column="1" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="2" 
                            CornerRadius="8" Margin="0,0,0,0">
                        
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="{StaticResource HeaderOrange}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="MuteButton" Grid.Column="0" Content="Mute" Click="MutePlayer_Click" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Active Players" Grid.Column="1" Foreground="White" FontWeight="Bold" FontSize="14" FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button x:Name="KickButton" Grid.Column="2" Content="Kick" Click="KickPlayer_Click" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Player List Headers-->
                            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" >
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Grid.Row="0" Text="Muted:" HorizontalAlignment="Center" Foreground="#FFB347" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="1" Grid.Row="0" Text="Name:" HorizontalAlignment="Center" Foreground="#FFB347" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                                <TextBlock Grid.Column="2" Grid.Row="0" Text="Location:" HorizontalAlignment="Center" Foreground="#FFB347" FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                                
                                <ScrollViewer Grid.Row="1" Grid.ColumnSpan="3" HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Auto">
                                    <ListView x:Name="PlayersListView" Background="Transparent" BorderThickness="0" SelectionMode="Single" SelectionChanged="PlayersListView_SelectionChanged" Margin="0,0,0,0">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Padding" Value="10,6"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="#2A2A2A"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="150"/>                                                        
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Muted Icon -->
                                                    <FontIcon Grid.Column="0"  
                                                        Glyph="&#xE198;" 
                                                        FontSize="16" 
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        Visibility="{Binding IsMuted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#FFF" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Consolas"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Location}" Foreground="#FFF" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Consolas"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                </ScrollViewer>
                            </Grid>

                            
                            </Grid>
                        
                    </Border>
                </Grid>
            </TabViewItem>
            <TabViewItem Header="Logs">
                <!-- Add content for Logs tab here -->
            </TabViewItem>
            <TabViewItem Header="Chat Monitor">
                <!-- Add content for Chat Monitor tab here -->
            </TabViewItem>
            <TabViewItem Header="Admin Console">
                <!-- Add content for Admin Console tab here -->
            </TabViewItem>
            <TabViewItem Header="Settings">
                <!-- Add content for Settings tab here -->
            </TabViewItem>
        </TabView>        

        <!-- ===== ROW 2: EVENT LOG ===== -->
        <Border Grid.Row="10" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="2" CornerRadius="8" Margin="18,0,18,18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{StaticResource DataGridHeader}" Padding="12,8" CornerRadius="6,6,0,0">
                    <TextBlock Text="Event Log" Foreground="#FF6600" FontWeight="Bold" FontSize="13" FontFamily="Consolas"/>                    
                </Border>
                <Border Grid.Row="0" Background="{StaticResource DataGridHeader}" Padding="12,8" CornerRadius="6,6,0,0">
                    <Button Content="Clear" Background="SlateGray" Foreground="#FFF" BorderBrush="#23262E" HorizontalAlignment="Right"
                            BorderThickness="1" FontFamily="Consolas" FontWeight="Bold" Width="70" Click="ClearEventLog_Click"/>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource DataGridHeader}" Padding="12,8" CornerRadius="6,6,0,0">
                    <Button Content="Clear" Background="SlateGray" Foreground="#FFF" BorderBrush="#23262E" HorizontalAlignment="Right"
            BorderThickness="1" FontFamily="Consolas" FontWeight="Bold" Width="70" Click="ClearEventLog_Click"/>
                </Border>


                <controls:DataGrid x:Name="EventLogDataGrid"
                          Grid.Row="1"
                          HorizontalScrollBarVisibility="Visible"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="{StaticResource DataGridRow}"
                          RowBackground="{StaticResource DataGridRow}"
                          AlternatingRowBackground="{StaticResource DataGridAltRow}"
                          BorderThickness="0"
                          IsReadOnly="True"
                          Margin="0,0,0,0"
                          HorizontalAlignment="Center">
                    <controls:DataGrid.ColumnHeaderStyle>
                        <Style TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="Background" Value="#181A1F"/>
                            <Setter Property="Foreground" Value="#FF6600"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="BorderBrush" Value="#23262E"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </controls:DataGrid.ColumnHeaderStyle>
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Time" Binding="{Binding Time}" MinWidth="85" />
                        <controls:DataGridTextColumn Header="Source" Binding="{Binding Source}" MinWidth="110" Width="130"/>
                        <controls:DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        <controls:DataGridTextColumn Header="Severity" Binding="{Binding Severity}" MinWidth="110"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>